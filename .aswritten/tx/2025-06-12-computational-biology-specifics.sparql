    narr:Actor_DrJamesThornton a narr:Actor ;
      skos:prefLabel "Dr. James Thornton" ;
      skos:note "Computational biologist; funded 4x by NSF CAREER and R01. Source of practitioner insight on computational biology grant proposals. Delivered mentoring session for early-career faculty at Cold Spring Harbor, 2025-06-12." .

    # ── Sample ─────────────────────────────────────────────────────────────
    narr:Sample_CompBioProposals a narr:Sample ;
      dct:title "Computational Biology Proposals: Domain-Specific Patterns" ;
      skos:note "Mentoring session with Dr. James Thornton, computational biologist (4x NSF CAREER and R01 funded), for early-career faculty at Cold Spring Harbor, 2025-06-12. Topics: framing computational contributions, preliminary data strategy, reproducibility as broader impact." ;
      narr:inputLength 1623 .

    # ── Narratives ─────────────────────────────────────────────────────────

    narr:Narrative_BiologyFramedComputation a narr:Narrative ;
      dct:source narr:Sample_CompBioProposals ;
      skos:broader narr:AudienceFrames ;
      narr:theme "Computational proposals succeed when every algorithmic contribution is framed in terms of the biological question it enables, because reviewers from wet-lab backgrounds fund the 'why' not the 'how'" ;
      skos:note "Structural bias exists against computational proposals: wet-lab reviewers may not perceive algorithm development as 'real' biology. The practitioner strategy is to describe methods not as 'novel algorithms' but as 'approaches that let us ask questions we couldn't ask before.' The algorithm is the how; the biology is the why. Reviewers fund the why." .

    narr:Narrative_CompBioPreliminaryData a narr:Narrative ;
      dct:source narr:Sample_CompBioProposals ;
      skos:broader narr:FrictionFailure ;
      narr:theme "Preliminary data for computational proposals must demonstrate biological discovery on real data, not pipeline performance on toy or simulated data" ;
      skos:note "For computational work, preliminary data is not about running a pipeline on toy data or benchmarks on simulated data. It means showing that the approach reveals something biologically unexpected in real data — even if the analysis is incomplete. One figure where the method finds something a standard approach misses is worth more than ten benchmarks on simulated data." .

    narr:Narrative_ReproducibilityAsBroaderImpact a narr:Narrative ;
      dct:source narr:Sample_CompBioProposals ;
      skos:broader narr:FrictionFailure ;
      narr:theme "Computational proposals have a built-in broader impact advantage in reproducibility, but only when framed as a community resource rather than a code deposit" ;
      skos:note "Every pipeline, workflow, and documented parameter choice is a contribution to open science. The framing must position these as community resources, not merely 'we'll put the code on GitHub.' Reviewers respond to the community resource frame, not the code-sharing frame." .

    # ── Claims ─────────────────────────────────────────────────────────────

    narr:Claim_AlgorithmIsHow a narr:Claim ;
      dct:source narr:Sample_CompBioProposals ;
      narr:aboutNode narr:Narrative_BiologyFramedComputation ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_BiologyFramedComputation ;
      skos:note "Direct quote from Dr. James Thornton: 'I never describe my methods as novel algorithms. I describe them as approaches that let us ask questions we couldn't ask before. The algorithm is how — the biology is why. Reviewers fund the why.' Conviction: Boulder — 4x-funded practitioner with direct reviewer-facing experience; consistent with reviewer-framing patterns in prior samples." .

    narr:Claim_OneFigureBeatenBenchmarks a narr:Claim ;
