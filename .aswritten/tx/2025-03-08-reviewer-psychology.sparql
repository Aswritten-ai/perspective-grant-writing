  narr:Tx_20250308T120000Z a prov:Activity ;
    dct:title "How Reviewers Actually Read Proposals — Dr. Sarah Chen + NSF panel webinar" ;
    prov:generatedAtTime "2025-03-08T12:00:00Z"^^xsd:dateTime ;
